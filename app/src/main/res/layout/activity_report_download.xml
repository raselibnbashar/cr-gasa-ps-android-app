<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/main_background">

    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="15dp"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/backBtn"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/arrow_back"
            app:tint="@color/white" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="রিপোর্ট ডাউনলোড"
            android:textColor="@color/white"
            android:textSize="20sp"
            android:textStyle="bold" />
    </LinearLayout>

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/searchLayout"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/header"
        android:layout_marginHorizontal="15dp"
        android:layout_marginTop="10dp"
        app:boxBackgroundColor="@color/slate_900"
        app:boxCornerRadiusBottomEnd="12dp"
        app:boxCornerRadiusBottomStart="12dp"
        app:boxCornerRadiusTopEnd="12dp"
        app:boxCornerRadiusTopStart="12dp"
        app:boxStrokeColor="@color/slate_700"
        app:hintEnabled="false"
        app:startIconDrawable="@android:drawable/ic_menu_search"
        app:startIconTint="@color/slate_400">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etSearchKeyword"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="ধারা বা কিওয়ার্ড দিয়ে খুঁজুন..."
            android:padding="12dp"
            android:textColor="@color/white"
            android:textColorHint="@color/slate_500" />
    </com.google.android.material.textfield.TextInputLayout>

    <TextView
        android:id="@+id/tvSelectDistrict"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/searchLayout"
        android:layout_marginHorizontal="15dp"
        android:layout_marginTop="20dp"
        android:text="জেলা নির্বাচন করুন"
        android:textColor="@color/slate_400"
        android:textSize="14sp" />

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnDownloadSelected"
        android:layout_width="wrap_content"
        android:layout_height="40dp"
        android:layout_below="@id/header"
        android:layout_toStartOf="@+id/btnDownloadAll"
        android:layout_marginEnd="8dp"
        android:layout_marginTop="10dp"
        android:background="@drawable/card_bg"
        android:backgroundTint="@color/emerald_400"
        android:text="নির্বাচিত"
        android:textColor="@color/white"
        android:textSize="12sp"
        android:paddingHorizontal="12dp"
        android:visibility="gone" />

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnDownloadAll"
        android:layout_width="wrap_content"
        android:layout_height="40dp"
        android:layout_below="@id/header"
        android:layout_toStartOf="@+id/btnDownloadMaster"
        android:layout_marginEnd="8dp"
        android:layout_marginTop="10dp"
        android:background="@drawable/card_bg"
        android:backgroundTint="@color/blue_600"
        android:text="সবগুলো আলাদা"
        android:textColor="@color/white"
        android:textSize="12sp"
        android:paddingHorizontal="12dp" />

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnDownloadMaster"
        android:layout_width="wrap_content"
        android:layout_height="40dp"
        android:layout_below="@id/header"
        android:layout_alignParentEnd="true"
        android:layout_marginEnd="15dp"
        android:layout_marginTop="10dp"
        android:background="@drawable/card_bg"
        android:backgroundTint="@color/blue_900"
        android:text="সবগুলো একসাথে"
        android:textColor="@color/white"
        android:textSize="12sp"
        android:paddingHorizontal="12dp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvDistricts"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/tvSelectDistrict"
        android:layout_marginTop="10dp"
        android:paddingHorizontal="15dp"
        android:clipToPadding="false" />

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:visibility="gone" />

</RelativeLayout>
