<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:paddingTop="10dp">

    <LinearLayout
        android:id="@+id/search_div"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="15dp">

        <EditText
            android:id="@+id/searchBarMain"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_bg"
            android:hint="পরোয়ানা খোঁজ"
            android:drawableLeft="@drawable/search"
            android:drawableTint="@color/slate_400"
            android:padding="10dp"
            android:drawablePadding="10dp"
            android:textColorHint="@color/slate_400"
            android:textColor="@color/white" />

        <LinearLayout
            android:id="@+id/statusFeature"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="10dp"
            android:weightSum="3">

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnRunningFilter"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="চলমান"
                android:textSize="12sp"
                android:textColor="@color/white"
                android:background="@drawable/card_bg"
                android:layout_marginEnd="2dp"
                app:cornerRadius="8dp"/>

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnDoneFilter"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="নিস্পত্তি"
                android:textSize="12sp"
                android:textColor="@color/white"
                android:background="@drawable/card_bg"
                android:layout_marginHorizontal="2dp"
                app:cornerRadius="8dp"/>

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnTotalFilter"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="মোট"
                android:textSize="12sp"
                android:textColor="@color/white"
                android:background="@drawable/card_bg"
                android:layout_marginStart="2dp"
                app:cornerRadius="8dp"/>

        </LinearLayout>

        <LinearLayout
            android:id="@+id/wardvillagewiseFeature"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="10dp"
            android:weightSum="2">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginEnd="5dp"
                app:cardBackgroundColor="@color/slate_900"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/blue_500"
                app:strokeWidth="1dp">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <Spinner
                        android:id="@+id/wardSpinner"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@android:color/transparent"
                        android:paddingStart="10dp"
                        android:paddingEnd="32dp"
                        android:spinnerMode="dropdown" />

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:layout_gravity="end|center_vertical"
                        android:layout_marginEnd="10dp"
                        android:src="@drawable/arrow_back"
                        android:rotation="270"
                        app:tint="@color/blue_400"
                        android:contentDescription="dropdown" />
                </FrameLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginStart="5dp"
                app:cardBackgroundColor="@color/slate_900"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/emerald_500"
                app:strokeWidth="1dp">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <Spinner
                        android:id="@+id/villageSpinner"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@android:color/transparent"
                        android:paddingStart="10dp"
                        android:paddingEnd="32dp"
                        android:spinnerMode="dropdown" />

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:layout_gravity="end|center_vertical"
                        android:layout_marginEnd="10dp"
                        android:src="@drawable/arrow_back"
                        android:rotation="270"
                        app:tint="@color/emerald_400"
                        android:contentDescription="dropdown" />
                </FrameLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

        <TextView
            android:id="@+id/searchTotalItem"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:layout_gravity="center"
            android:textColor="@color/emerald_400"
            android:textStyle="bold"
            android:textSize="14sp" />

    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/accusedFrontList"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/search_div"
        android:paddingHorizontal="15dp"
        android:paddingBottom="10dp"
        android:clipToPadding="false"
        tools:listitem="@layout/accused_list" />

</RelativeLayout>