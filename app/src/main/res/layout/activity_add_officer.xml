<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/main_background"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="15dp"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/backBtn"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/arrow_back"
            app:tint="@color/white" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="নতুন অফিসার যোগ করুন"
            android:textColor="@color/white"
            android:textSize="20sp"
            android:textStyle="bold" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/header"
        android:padding="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:hint="নাম ও পদবী"
                app:boxStrokeColor="@color/blue_500"
                app:hintTextColor="@color/blue_400"
                app:startIconDrawable="@drawable/user"
                app:startIconTint="@color/slate_400">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/inputOfficerName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/white" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:hint="মোবাইল নম্বর"
                app:boxStrokeColor="@color/blue_500"
                app:hintTextColor="@color/blue_400"
                app:startIconDrawable="@android:drawable/stat_sys_phone_call"
                app:startIconTint="@color/slate_400">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/inputOfficerMobile"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/white" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:hint="ওয়ার্ড নং"
                app:boxStrokeColor="@color/blue_500"
                app:hintTextColor="@color/blue_400"
                app:startIconDrawable="@drawable/list"
                app:startIconTint="@color/slate_400">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/inputOfficerWard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/white" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:hint="ইউজার আইডি (লগইন এর জন্য)"
                app:boxStrokeColor="@color/blue_500"
                app:hintTextColor="@color/blue_400"
                app:startIconDrawable="@drawable/user"
                app:startIconTint="@color/slate_400">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/inputOfficerUserId"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/white" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:hint="পাসওয়ার্ড"
                app:boxStrokeColor="@color/blue_500"
                app:hintTextColor="@color/blue_400"
                app:passwordToggleEnabled="true"
                app:startIconDrawable="@drawable/ic_moon"
                app:startIconTint="@color/slate_400">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/inputOfficerPassword"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textPassword"
                    android:textColor="@color/white" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/saveOfficerBtn"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="অফিসার যোগ করুন"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold"
                app:backgroundTint="@color/emerald_400"
                app:cornerRadius="12dp" />

        </LinearLayout>
    </ScrollView>

</RelativeLayout>
